# 数据库（使用内置 PostgreSQL 时，DATABASE_URL 中的 host 填 db）
DATABASE_URL="postgresql://plain_blog:changeme@db:5432/plain_blog"

# 内置 PostgreSQL 配置（仅 docker compose --profile builtin-db 时生效）
POSTGRES_USER=plain_blog
POSTGRES_PASSWORD=changeme
POSTGRES_DB=plain_blog

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# 阿里云 OSS
OSS_REGION="oss-cn-hangzhou"
OSS_BUCKET="your-bucket-name"
OSS_ACCESS_KEY_ID="your-access-key-id"
OSS_ACCESS_KEY_SECRET="your-access-key-secret"
OSS_ROLE_ARN="acs:ram::your-role-arn"
